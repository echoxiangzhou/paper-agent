# Paper Summary Agent - Backend Environment Variables

# Environment
ENVIRONMENT=development  # development, staging, production

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days
REFRESH_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Database
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=paper_agent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI Services
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_AI_MODEL=google/gemini-flash-1.5
AI_REQUEST_TIMEOUT=60
AI_MAX_RETRIES=3

# Email Configuration (for notifications)
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@paper-agent.com
EMAILS_FROM_NAME=Paper Summary Agent

# Firecrawl (for web scraping)
FIRECRAWL_API_KEY=your-firecrawl-api-key
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# File Upload
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# Features
ENABLE_BACKGROUND_TASKS=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true